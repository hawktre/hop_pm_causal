# ==============================================================================
# Quarto and Publication Artifacts
# ==============================================================================
.quarto/
*_files/
*.pdf
*.docx
output/figures/hmc_diagnostics/

# ==============================================================================
# Stan / CmdStan Compilation & Execution Artifacts
# ==============================================================================
# Ignore compiled Stan executables in src/ (files without extensions)
src/*
!src/*/
!src/*.py
!src/*.stan
!src/*.md

# Windows executables and compilation artifacts
src/*.exe
src/*.hpp
src/*.cpp
src/*.o
src/*.d

# ==============================================================================
# Data and Results (Generated files should not be tracked)
# ==============================================================================
# Ignore all processed data files
data/processed/*.csv
data/processed/*.npz

# Ignore all generated results and MCMC fits
results/

# Ignore local background runs/logs
background/*
